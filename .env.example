# Токен бота от @BotFather
BOT_TOKEN=1234567890:AAH...

# Твой Telegram ID (владелец). Узнать: напиши боту /id
OWNER_ID=123456789

# Необязательно: канал/группа для логов (отрицательный id для групп)
LOG_CHANNEL_ID=

# Необязательно: ID модераторов через запятую
MODERATOR_IDS=

# Путь к базе данных
DB_PATH=data/srank.db

# ── Экономика (Мана-руда) ────────────────────────────────────────────────
MANA_PER_MESSAGE=1
MANA_MESSAGE_COOLDOWN=30
MANA_DAILY_BONUS=50
MANA_INVITE_BONUS=200
MANA_TRANSFER_FEE_PCT=5

# ── Рефералы / VIP ───────────────────────────────────────────────────────
VIP_INVITE_THRESHOLD=50
VIP_CHAT_LINK=

# ── Реклама ──────────────────────────────────────────────────────────────
ADS_ENABLED=1
ADS_DAILY_LIMIT_PER_CHAT=1
ADS_SEND_HOUR=12

# ── Платежи (Telegram Stars) ─────────────────────────────────────────────
PAYMENTS_ENABLED=1

# Канал-витрина бота (анонсы/реклама), необязательно
BOT_CHANNEL_ID=

# ── Cursor-мост (команда /cursor, Cloud Agents API) ─────────────────────
# Из лички бота отправляешь задачи облачному агенту Cursor в GitHub-репо.
# Ключ: https://cursor.com/dashboard/integrations (User API Key).
# Репозиторий должен быть подключён к твоему аккаунту Cursor.
CURSOR_API_KEY=          # СЮДА ВСТАВИТЬ ключ вида crsr_xxx
# GitHub-репозиторий и ветка (дефолт — этот проект, main):
CURSOR_REPO_URL=https://github.com/ciseuadm/Manager-S-Rank
CURSOR_REPO_REF=main
# 1 = пушить прямо в CURSOR_REPO_REF (main), без отдельных веток — рекомендуется
CURSOR_WORK_ON_BRANCH=1
# 0 = без PR (деплой через Railway с main). 1 = открывать PR (нужен merge в GitHub)
CURSOR_AUTO_PR=0
# Необязательно: ID моделей под кнопки Sonnet/Opus (/cursormodels в боте).
CURSOR_MODEL_SONNET=
CURSOR_MODEL_OPUS=

# ── Экономика заданий и обмена ───────────────────────────────────────────
# 50 руды = 1 ₽ для пользователя. Подписка 2 ₽ → 50 руды охотнику.
MANA_PER_RUB=50
TASK_REWARD_SUBSCRIBE=50
TASK_REVENUE_RUB=2
# 1000 ⭐ = $16.20, курс $1 = 76 ₽ (для расчёта цен подарков)
STARS_USD_CENTS_PER_1000=1620
USD_RUB_RATE=76
REDEEM_MARGIN_PCT=30
REDEEM_MIN=1200

# ── Бэкапы БД ─────────────────────────────────────────────────────────────
# Ежедневный снимок БД в папку backups/ (час по UTC) и сколько штук хранить.
BACKUP_HOUR=4
BACKUP_KEEP=14
