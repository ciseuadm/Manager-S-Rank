# Токен бота от @BotFather
BOT_TOKEN=1234567890:AAH...

# Твой Telegram ID (владелец). Узнать: напиши боту /id
OWNER_ID=123456789

# Необязательно: канал/группа для логов (отрицательный id для групп)
LOG_CHANNEL_ID=

# Необязательно: ID модераторов через запятую
MODERATOR_IDS=

# Путь к базе данных
DB_PATH=data/srank.db

# ── Экономика (Мана-руда) ────────────────────────────────────────────────
MANA_PER_MESSAGE=1
MANA_MESSAGE_COOLDOWN=30
MANA_DAILY_BONUS=50
MANA_INVITE_BONUS=200
MANA_TRANSFER_FEE_PCT=5

# ── Рефералы / VIP ───────────────────────────────────────────────────────
VIP_INVITE_THRESHOLD=50
VIP_CHAT_LINK=

# ── Реклама ──────────────────────────────────────────────────────────────
ADS_ENABLED=1
ADS_DAILY_LIMIT_PER_CHAT=1
ADS_SEND_HOUR=12

# ── Платежи (Telegram Stars) ─────────────────────────────────────────────
PAYMENTS_ENABLED=1

# Канал-витрина бота (анонсы/реклама), необязательно
BOT_CHANNEL_ID=

# ── Cursor-мост (команда /cursor) ────────────────────────────────────────
# Позволяет из лички бота отправлять задачи агенту Cursor прямо в этот проект.
# Ключ возьми тут: https://cursor.com/dashboard/integrations (User API Key).
# Без ключа мост просто выключен, остальной бот работает как обычно.
CURSOR_API_KEY=          # СЮДА ВСТАВИТЬ ключ вида cursor_xxx
# Необязательно: переопределить ID моделей под кнопки Sonnet/Opus,
# если дефолтные не совпадут с твоим аккаунтом (узнать: /cursormodels в боте).
CURSOR_MODEL_SONNET=
CURSOR_MODEL_OPUS=

# ── Бэкапы БД ─────────────────────────────────────────────────────────────
# Ежедневный снимок БД в папку backups/ (час по UTC) и сколько штук хранить.
BACKUP_HOUR=4
BACKUP_KEEP=14
